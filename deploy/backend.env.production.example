# Unitap — Production Backend Environment
# Copied automatically by deploy.sh to /opt/ezunitap/backend/.env
# JWT_SECRET will be auto-generated on first install (openssl rand -hex 64)

MONGO_URL=mongodb://localhost:27017
DB_NAME=unitap_prod

# Comma-separated, EXACT origins (no trailing slash, no wildcard with credentials)
CORS_ORIGINS=https://ezunitap.com,https://www.ezunitap.com

JWT_SECRET=GENERATED_BY_DEPLOY_SCRIPT
JWT_EXPIRY_HOURS=12

# Super admin (auto-seeded at startup if user doesn't exist)
SUPER_ADMIN_EMAIL=pzsuave007@gmail.com
SUPER_ADMIN_PASSWORD=Uni2mkt007!
SUPER_ADMIN_BUSINESS_NAME=Unitap HQ

# Optional secondary admin
ADMIN_EMAIL=admin@ezunitap.com
ADMIN_PASSWORD=Uni2mkt007!
ADMIN_BUSINESS_NAME=Unitap Admin

# Emergent LLM Key (GPT-5.2 + Nano Banana + Object Storage)
# Replace with YOUR key from the Emergent dashboard before first run!
EMERGENT_LLM_KEY=sk-emergent-eEbDa9fBf2b61E3F28

APP_NAME=unitap
